# Get a free key at https://aistudio.google.com/apikey
# Free tier: 1,500 requests/day. No card required.
GEMINI_API_KEY=

DRIFT_DB_PATH=./data/drift.db
DRIFT_MODEL=gemini-2.5-flash

# --- Auth ---
# Leave DRIFT_PASSWORD empty for local dev (no auth, /app is open).
# Set both before deploying publicly. Generate a strong secret with:
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
DRIFT_PASSWORD=
DRIFT_AUTH_SECRET=

# Optional. If set, /api/cron requires `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron sends this header automatically.
CRON_SECRET=

# Optional — required only if you add email-kind webhooks.
# Free tier: resend.com, no card. The default sender `onboarding@resend.dev`
# works without a verified domain but can only email the address that owns
# the Resend account. Verify a domain to send to anyone.
RESEND_API_KEY=
DRIFT_EMAIL_FROM=Drift <onboarding@resend.dev>
